<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Forge Digital</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #0f172a;
      color: white;
      line-height: 1.6;
    }

    nav {
      display: flex;
      justify-content: space-between;
      padding: 20px 40px;
      background: #111827;
      position: sticky;
      top: 0;
    }

    nav h1 {
      color: #4ade80;
    }

    nav a {
      color: white;
      margin-left: 20px;
      text-decoration: none;
    }

    .hero {
      text-align: center;
      padding: 120px 20px;
      background: linear-gradient(135deg, #1e293b, #0f172a);
    }

    .hero h2 {
      font-size: 48px;
      margin-bottom: 20px;
    }

    .hero p {
      font-size: 18px;
      color: #cbd5e1;
      margin-bottom: 30px;
    }

    .btn {
      background: #4ade80;
      color: black;
      padding: 12px 25px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-weight: bold;
      text-decoration: none;
    }

    .section {
      padding: 80px 20px;
      text-align: center;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-top: 30px;
      padding: 0 20px;
    }

    .card {
      background: #1f2937;
      padding: 20px;
      border-radius: 12px;
    }

    footer {
      text-align: center;
      padding: 30px;
      background: #111827;
      margin-top: 40px;
    }
  </style>
</head>

<body>

  <nav>
    <h1>Forge Digital</h1>
    <div>
      <a href="#services">Services</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
    </div>
  </nav>

  <section class="hero">
    <h2>Modern Websites That Grow Your Business</h2>
    <p>We build fast, clean, mobile-friendly websites for local businesses.</p>
    <a class="btn" href="#contact">Get a Free Quote</a>
  </section>

  <section id="about" class="section">
    <h2>About Forge Digital</h2>
    <p>
      We help small businesses get online with modern websites that look professional
      and bring in more customers.
    </p>
  </section>

  <section id="services" class="section">
    <h2>Services</h2>

    <div class="cards">
      <div class="card">
        <h3>Business Websites</h3>
        <p>Clean, modern websites for any business.</p>
      </div>

      <div class="card">
        <h3>Landing Pages</h3>
        <p>High-converting pages to get more leads.</p>
      </div>

      <div class="card">
        <h3>Redesigns</h3>
        <p>Upgrade outdated websites into modern designs.</p>
      </div>
    </div>
  </section>

  <section id="contact" class="section">
    <h2>Contact</h2>
    <p>Email us at: forgesupport@example.com</p>
  </section>

  <footer>
    <p>© 2026 Forge Digital. All rights reserved.</p>
  </footer>

</body>
</html>
